# Local Supabase — copy to .env.local and fill in (npm run dev)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Production Supabase — copy to .env.production.local and fill in (npm run dev:prod)
# Same variable names; use your hosted project URL and anon key from Supabase Settings > API.

# Stripe.js publishable keys (client-side SCA / 3D-Secure confirmation).
# One per mode: a sandbox project's PaymentIntents are test-mode and require the
# test key; live projects require the live key. Both are safe to expose.
NEXT_PUBLIC_STRIPE_TEST_PUBLISHABLE_KEY=
NEXT_PUBLIC_STRIPE_LIVE_PUBLISHABLE_KEY=
